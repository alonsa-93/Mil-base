# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── JWT ─────────────────────────────────────────────────────────────────────
# PRODUCTION: Use a 64-char random secret: openssl rand -hex 32
JWT_SECRET=milbase-super-secret-key-2024

# ─── Feature Flags ───────────────────────────────────────────────────────────
BYPASS_2FA=true

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Base URL: https://<project-ref>.supabase.co  (no /rest/v1 suffix)
SUPABASE_URL=https://afvtqoomzwwuatqxfnki.supabase.co

# ⚠️  SERVICE_ROLE_KEY — BACKEND ONLY. NEVER expose to frontend.
# Find in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ANON_KEY — safe for frontend. Listed here for reference only.
# Frontend reads this via VITE_SUPABASE_ANON_KEY in .env
SUPABASE_ANON_KEY=sb_publishable_TKHzMqw4ox1HZdowGyejgA_xf33erh_

# ─── Logging ─────────────────────────────────────────────────────────────────
# development | production
LOG_LEVEL=info
NODE_ENV=development
